@page
@model ConsultaPantone.Pages.HistoricoModel
@{
    ViewData["Title"] = "Histórico Universal de Envios";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Segoe UI', sans-serif;
    }

    .header-hist {
        background: linear-gradient(135deg, #2c3e50 0%, #000000 100%);
        color: white;
        padding: 20px 0;
        margin-bottom: 30px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .search-box {
        background: white;
        padding: 20px;
        border-radius: 15px;
        shadow: 0 4px 15px rgba(0,0,0,0.05);
        border-left: 5px solid #0d6efd;
    }

    .table-hist {
        background: white;
        border-radius: 10px;
        overflow: hidden;
    }

    .badge-pantone {
        background-color: #343a40;
        color: #f8f9fa;
        font-weight: 600;
        padding: 6px 12px;
    }

    .val-num {
        color: #0d6efd;
        font-weight: bold;
    }
</style>

<div class="header-hist">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0"><i class="bi bi-clock-history"></i> Histórico de Envios</h2>
            <small class="opacity-75">Pesquise por cliente, código ID ou código Pantone</small>
        </div>
        <a href="/Index" class="btn btn-outline-light"><i class="bi bi-house"></i> Voltar</a>
    </div>
</div>

<div class="container mb-5">
    <div class="search-box mb-4">
        <form method="get">
            <div class="row g-2">
                <div class="col-md-10">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" asp-for="Filtro" class="form-control border-start-0" placeholder="Ex: Nome do Cliente, ID 105 ou Pantone 18-1662...">
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-lg w-100" type="submit">Pesquisar</button>
                </div>
            </div>
        </form>
    </div>

    <div class="table-hist shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle text-center mb-0">
                <thead class="table-dark small">
                    <tr>
                        <th class="text-start ps-4">DATA/HORA</th>
                        <th class="text-start">CLIENTE</th>
                        <th>PANTONE</th>
                        <th>CORCO</th>
                        <th>CORPES</th>
                        <th>CORPA</th>
                        <th>POLI</th>
                        <th>ALT</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Envios)
                    {
                        <tr>
                            <td class="text-start ps-4">
                                <span class="d-block fw-bold">@item.Data.ToString("dd/MM/yyyy")</span>
                                <small class="text-muted">@item.Data.ToString("HH:mm")</small>
                            </td>
                            <td class="text-start">
                                <div class="fw-bold text-uppercase">@item.NomeCliente</div>
                                <small class="badge bg-light text-dark border">ID: @item.CodCliente</small>
                            </td>
                            <td><span class="badge badge-pantone">@item.Pantone</span></td>
                            <td class="val-num">@(item.Co ?? "-")</td>
                            <td class="val-num">@(item.Pes ?? "-")</td>
                            <td class="val-num">@(item.Pa ?? "-")</td>
                            <td class="val-num">@(item.Poli ?? "-")</td>
                            <td class="val-num">@(item.Alt ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Envios.Any())
                    {
                        <tr>
                            <td colspan="8" class="py-5 text-muted">
                                <i class="bi bi-info-circle fs-2"></i><br>
                                Nenhum registro encontrado para "@Model.Filtro".
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>